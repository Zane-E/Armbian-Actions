#!/bin/bash

# ==============================================================================
#  脚本名称：armbian-apt
#  脚本功能：切换系统软件源，并按需注释 Armbian / armbian-config 源
# ==============================================================================

set -o pipefail

readonly DEBIAN_SOURCE_FILE="/etc/apt/sources.list.d/debian.sources"
readonly DEBIAN_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/debian.sources.bak"
readonly UBUNTU_SOURCE_FILE="/etc/apt/sources.list.d/ubuntu.sources"
readonly UBUNTU_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/ubuntu.sources.bak"
readonly ARMBIAN_SOURCE_FILE="/etc/apt/sources.list.d/armbian.sources"
readonly ARMBIAN_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/armbian.sources.bak"
readonly ARMBIAN_CONFIG_SOURCE_FILE="/etc/apt/sources.list.d/armbian-config.sources"
readonly ARMBIAN_CONFIG_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/armbian-config.sources.bak"
readonly DEBIAN_KEYRING="/usr/share/keyrings/debian-archive-keyring.gpg"
readonly UBUNTU_KEYRING="/usr/share/keyrings/ubuntu-archive-keyring.gpg"
readonly OS_RELEASE_FILE="/etc/os-release"
readonly MANAGED_SOURCE_MARK="# Generated by armbian-apt"

readonly STEPS="[\033[95m 步骤 \033[0m]"
readonly INFO="[\033[94m 信息 \033[0m]"
readonly SUCCESS="[\033[92m 成功 \033[0m]"
readonly OPTIONS="[\033[93m 选项 \033[0m]"
readonly ERROR="[\033[91m 错误 \033[0m]"
readonly SN="[\033[96m 序号 \033[0m]"

VERSION_CODEID=""
VERSION_CODENAME=""
SYSTEM_ARCH=""
UBUNTU_SOURCE_PATH="ubuntu-ports"
MIRROR_URL=""

log_error() {
    echo -e "${ERROR} ${1}"
}

die() {
    log_error "${1}"
    exit 1
}

require_command() {
    command -v "${1}" >/dev/null 2>&1 || die "缺少依赖命令：[\033[92m ${1} \033[0m]"
}

require_root() {
    [[ "$(id -u)" -eq 0 ]] || die "请使用 root 用户运行！"
}

prompt_yes_no() {
    local prompt="${1}"
    local default="${2:-y}"
    local choice

    read -r -p "$(echo -e "${prompt}")" choice
    choice="${choice:-${default}}"
    [[ "${choice}" =~ ^[Yy]$ ]]
}

check_dependencies() {
    local cmd
    local required_commands=(cp dpkg grep id sed)

    for cmd in "${required_commands[@]}"; do
        require_command "${cmd}"
    done
}

load_release_info() {
    [[ -f "${OS_RELEASE_FILE}" ]] || die "未检测到系统的 release 文件！"
    # shellcheck disable=SC1090
    source "${OS_RELEASE_FILE}"

    VERSION_CODEID="${ID}"
    [[ -n "${VERSION_CODEID}" ]] || die "未检测到系统的 VERSION_CODEID！"
    [[ -n "${VERSION_CODENAME}" ]] || die "未检测到系统的 VERSION_CODENAME！"
}

load_system_arch() {
    SYSTEM_ARCH=$(dpkg --print-architecture 2>/dev/null) || die "未检测到系统架构！"
    [[ -n "${SYSTEM_ARCH}" ]] || die "系统架构为空！"

    case "${SYSTEM_ARCH}" in
        amd64|i386|x32)
            UBUNTU_SOURCE_PATH="ubuntu"
            ;;
        *)
            UBUNTU_SOURCE_PATH="ubuntu-ports"
            ;;
    esac
}

is_managed_source_file() {
    local source_file="${1}"

    [[ -f "${source_file}" ]] && grep -q "^${MANAGED_SOURCE_MARK}$" "${source_file}"
}

backup_if_needed() {
    local source_file="${1}"
    local backup_file="${2}"

    if [[ -f "${source_file}" && ! -f "${backup_file}" ]] && ! is_managed_source_file "${source_file}"; then
        cp -f "${source_file}" "${backup_file}" || die "备份源文件失败：${source_file}"
    fi
}

backup_sources() {
    backup_if_needed "${DEBIAN_SOURCE_FILE}" "${DEBIAN_SOURCE_BACKUP_FILE}"
    backup_if_needed "${UBUNTU_SOURCE_FILE}" "${UBUNTU_SOURCE_BACKUP_FILE}"
    backup_if_needed "${ARMBIAN_SOURCE_FILE}" "${ARMBIAN_SOURCE_BACKUP_FILE}"
    backup_if_needed "${ARMBIAN_CONFIG_SOURCE_FILE}" "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}"
}

comment_active_lines() {
    local file="${1}"

    [[ -f "${file}" ]] || return 0
    sed -i 's/^[^#]/#&/' "${file}" || die "注释源文件失败：${file}"
}

has_active_lines() {
    local file="${1}"

    grep -q '^[^#]' "${file}"
}

init_source_file() {
    local source_file="${1}"

    {
        echo "${MANAGED_SOURCE_MARK}"
        echo
    } > "${source_file}" || die "无法写入源文件：${source_file}"
}

write_deb822_stanza() {
    local components="${4}"
    local signed_by="${5}"
    local source_file="${1}"
    local suites="${3}"
    local uri="${2}"

    {
        echo "Types: deb"
        echo "URIs: ${uri}"
        echo "Suites: ${suites}"
        echo "Components: ${components}"
        [[ -f "${signed_by}" ]] && echo "Signed-By: ${signed_by}"
        echo
    } >> "${source_file}" || die "无法写入源文件：${source_file}"
}

write_debian_sources() {
    local components
    local main_suites
    local security_suite

    case "${VERSION_CODENAME}" in
        buster)
            components="main contrib non-free"
            main_suites="${VERSION_CODENAME} ${VERSION_CODENAME}-updates"
            security_suite="${VERSION_CODENAME}/updates"
            ;;
        bullseye)
            components="main contrib non-free"
            main_suites="${VERSION_CODENAME} ${VERSION_CODENAME}-updates ${VERSION_CODENAME}-backports"
            security_suite="${VERSION_CODENAME}-security"
            ;;
        bookworm|trixie|forky)
            components="main contrib non-free non-free-firmware"
            main_suites="${VERSION_CODENAME} ${VERSION_CODENAME}-updates ${VERSION_CODENAME}-backports"
            security_suite="${VERSION_CODENAME}-security"
            ;;
        sid|unstable)
            components="main contrib non-free non-free-firmware"
            main_suites="${VERSION_CODENAME}"
            security_suite=""
            ;;
        *)
            die "未检测到 Debian 系统版本：[ ${VERSION_CODENAME} ]"
            ;;
    esac

    init_source_file "${DEBIAN_SOURCE_FILE}"
    write_deb822_stanza "${DEBIAN_SOURCE_FILE}" "http://${MIRROR_URL}/debian" "${main_suites}" "${components}" "${DEBIAN_KEYRING}"

    if [[ -n "${security_suite}" ]]; then
        write_deb822_stanza "${DEBIAN_SOURCE_FILE}" "http://${MIRROR_URL}/debian-security" "${security_suite}" "${components}" "${DEBIAN_KEYRING}"
    fi
}

write_ubuntu_sources() {
    local components="main restricted universe multiverse"
    local suites="${VERSION_CODENAME} ${VERSION_CODENAME}-security ${VERSION_CODENAME}-updates ${VERSION_CODENAME}-backports"

    init_source_file "${UBUNTU_SOURCE_FILE}"
    write_deb822_stanza "${UBUNTU_SOURCE_FILE}" "http://${MIRROR_URL}/${UBUNTU_SOURCE_PATH}" "${suites}" "${components}" "${UBUNTU_KEYRING}"
}

write_system_sources() {
    echo -e "${STEPS} 开始更改系统软件源：[\033[92m ${MIRROR_URL} \033[0m]"
    echo -e "${INFO} 系统版本：[\033[92m ${VERSION_CODENAME} \033[0m]"
    echo -e "${INFO} 系统架构：[\033[92m ${SYSTEM_ARCH} \033[0m]"
    echo -e "${INFO} 源文件格式：[\033[92m Deb822 .sources \033[0m]"

    case "${VERSION_CODENAME}" in
        buster|bullseye|bookworm|trixie|forky|sid|unstable)
            write_debian_sources
            ;;
        focal|jammy|noble|resolute)
            write_ubuntu_sources
            ;;
        *)
            die "未检测到系统版本：[ ${VERSION_CODENAME} ]"
            ;;
    esac
}

change_system_sources() {
    write_system_sources
    echo -e "${SUCCESS} 成功更改系统软件源！"
}

restore_default_sources() {
    if [[ -f "${DEBIAN_SOURCE_BACKUP_FILE}" ]]; then
        cp -f "${DEBIAN_SOURCE_BACKUP_FILE}" "${DEBIAN_SOURCE_FILE}" || die "恢复 Debian 默认源失败！"
        echo -e "${SUCCESS} 成功恢复 [\033[92m ${VERSION_CODENAME} \033[0m] 默认源！"
    fi

    if [[ -f "${UBUNTU_SOURCE_BACKUP_FILE}" ]]; then
        cp -f "${UBUNTU_SOURCE_BACKUP_FILE}" "${UBUNTU_SOURCE_FILE}" || die "恢复 Ubuntu 默认源失败！"
        echo -e "${SUCCESS} 成功恢复 [\033[92m ${VERSION_CODENAME} \033[0m] 默认源！"
    fi

    if [[ -f "${ARMBIAN_SOURCE_BACKUP_FILE}" ]]; then
        if prompt_yes_no "${OPTIONS} 是否恢复 armbian 默认源？[\033[92mY\033[0m/n]: " "y"; then
            cp -f "${ARMBIAN_SOURCE_BACKUP_FILE}" "${ARMBIAN_SOURCE_FILE}" || die "恢复 armbian 默认源失败！"
            echo -e "${SUCCESS} 成功恢复 [\033[92m armbian \033[0m] 默认源！"
        else
            echo -e "${INFO} 跳过恢复 armbian 默认源！"
        fi
    fi

    if [[ -f "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}" ]]; then
        if prompt_yes_no "${OPTIONS} 是否恢复 armbian-config 默认源？[\033[92mY\033[0m/n]: " "y"; then
            cp -f "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}" "${ARMBIAN_CONFIG_SOURCE_FILE}" || die "恢复 armbian-config 默认源失败！"
            echo -e "${SUCCESS} 成功恢复 [\033[92m armbian-config \033[0m] 默认源！"
        else
            echo -e "${INFO} 跳过恢复 armbian-config 默认源！"
        fi
    fi

    exit 0
}

select_mirror_site() {
    local source_id="${1}"

    echo -e "${INFO} 您选择的源对应序号：[\033[92m ${source_id} \033[0m]"

    case "${source_id}" in
        0) restore_default_sources ;;
        1) MIRROR_URL="mirrors.cernet.edu.cn" ;;
        2) MIRROR_URL="mirrors.ustc.edu.cn" ;;
        3) MIRROR_URL="mirrors.bfsu.edu.cn" ;;
        4) MIRROR_URL="mirrors.tuna.tsinghua.edu.cn" ;;
        5) MIRROR_URL="mirrors.aliyun.com" ;;
    esac

    change_system_sources
}

system_source_manage() {
    local source_id

    echo -e "${INFO} 请选择适用于 [\033[92m ${VERSION_CODENAME} \033[0m] 的镜像软件源！"
    echo -e "${SN} [\033[96m 0 \033[0m] -> [\033[92m 恢复默认软件源 \033[0m]"
    echo -e "${SN} [\033[96m 1 \033[0m] -> [\033[92m 高校联合•自动选择 \033[0m]"
    echo -e "${SN} [\033[96m 2 \033[0m] -> [\033[92m 中国科学技术大学 \033[0m]"
    echo -e "${SN} [\033[96m 3 \033[0m] -> [\033[92m 北京外国语大学 \033[0m]"
    echo -e "${SN} [\033[96m 4 \033[0m] -> [\033[92m 清华大学 \033[0m]"
    echo -e "${SN} [\033[96m 5 \033[0m] -> [\033[92m 阿里云 \033[0m]"
    echo -e "${SN} [\033[96m 6 \033[0m] -> [\033[92m 退出 \033[0m]"

    while true; do
        read -r -p "$(echo -ne "${OPTIONS} 请输入序号 [\033[96m 0-6 \033[0m] [ 回车默认 \033[96m1\033[0m ]：")" source_id
        source_id="${source_id:-1}"

        if [[ "${source_id}" =~ ^[0-9]+$ && "${source_id}" -ge 0 && "${source_id}" -le 6 ]]; then
            if [[ "${source_id}" -eq 6 ]]; then
                echo -e "${INFO} 已退出选择！"
                exit 0
            fi
            select_mirror_site "${source_id}"
            break
        fi

        echo -e "${ERROR} 无效选择，重新输入！"
    done
}

disable_source_file() {
    local label="${1}"
    local source_file="${2}"
    local choice

    if [[ ! -f "${source_file}" ]]; then
        echo -e "${INFO} 未找到 ${label} 源文件，已跳过！"
        return 0
    fi

    read -r -p "$(echo -ne "${OPTIONS} 是否注释 ${label} 源？[\033[92mY\033[0m/n]：")" choice
    case "${choice}" in
        [nN])
            echo -e "${INFO} 保持当前状态，不进行注释！"
            ;;
        *)
            if ! has_active_lines "${source_file}"; then
                echo -e "${INFO} ${label} 源已注释，无需修改！"
                return 0
            fi
            comment_active_lines "${source_file}"
            echo -e "${SUCCESS} 成功注释 [\033[92m ${label} \033[0m] 源！"
            ;;
    esac
}

main() {
    check_dependencies
    require_root
    load_release_info
    load_system_arch
    backup_sources
    system_source_manage
    disable_source_file "armbian" "${ARMBIAN_SOURCE_FILE}"
    disable_source_file "armbian-config" "${ARMBIAN_CONFIG_SOURCE_FILE}"
}

main "$@"
