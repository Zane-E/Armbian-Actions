#!/bin/bash

# ==============================================================================
#  脚本名称：armbian-sync
#  脚本功能：同步 Armbian-Actions 仓库中的 /patch/sbin 脚本到 /usr/sbin
# ==============================================================================

set -o pipefail

readonly BASE_URL="https://raw.githubusercontent.com/Zane-E/Armbian-Actions/main/patch/sbin"
readonly API_URL="https://api.github.com/repos/Zane-E/Armbian-Actions/contents/patch/sbin"
readonly TARGET_DIR="/usr/sbin"

readonly STEPS="[\033[95m 步骤 \033[0m]"
readonly INFO="[\033[94m 信息 \033[0m]"
readonly SUCCESS="[\033[92m 成功 \033[0m]"
readonly ERROR="[\033[91m 错误 \033[0m]"

TEMP_DIR=""
VERSION_CODENAME=""
ARCH=""
SCRIPT_NAME=""
FILES=""

log_error() {
    echo -e "${ERROR} ${1}"
}

die() {
    log_error "${1}"
    exit 1
}

require_command() {
    command -v "${1}" >/dev/null 2>&1 || die "缺少依赖命令：[\033[92m ${1} \033[0m]"
}

require_root() {
    [[ "$(id -u)" -eq 0 ]] || die "请使用 root 用户运行！"
}

cleanup() {
    [[ -n "${TEMP_DIR}" && -d "${TEMP_DIR}" ]] && rm -rf "${TEMP_DIR}"
}

check_dependencies() {
    local cmd
    local required_commands=(bash basename chmod curl id jq mkdir mktemp mv rm uname)

    for cmd in "${required_commands[@]}"; do
        require_command "${cmd}"
    done
}

create_temp_dir() {
    TEMP_DIR=$(mktemp -d) || die "创建临时目录失败！"
    trap cleanup EXIT
}

download_file() {
    local output_file="${1}"
    local url="${2}"

    curl -fsSL --retry 3 --retry-delay 1 --connect-timeout 5 --max-time 30 \
        -o "${output_file}" "${url}" >/dev/null 2>&1
}

fetch_text() {
    local url="${1}"

    curl -fsSL --retry 3 --retry-delay 1 --connect-timeout 5 --max-time 30 "${url}"
}

load_system_info() {
    [[ -f /etc/os-release ]] || die "未找到 /etc/os-release 文件！"
    # shellcheck disable=SC1091
    source /etc/os-release

    ARCH=$(uname -m)
    SCRIPT_NAME=$(basename "${0}")
}

get_remote_scripts() {
    local skip_install_pve=false

    echo -e "${STEPS} 正在获取文件列表..."

    if [[ ! "${VERSION_CODENAME}" =~ ^(bookworm|trixie)$ || ! "${ARCH}" =~ ^(aarch64|arm64)$ ]]; then
        skip_install_pve=true
    fi

    FILES=$(fetch_text "${API_URL}" 2>/dev/null |
        jq -r --arg SCRIPT_NAME "${SCRIPT_NAME}" --arg skip_install_pve "${skip_install_pve}" '
            .[]
            | select(.type == "file")
            | select(.name != $SCRIPT_NAME)
            | select($skip_install_pve != "true" or .name != "install-pve")
            | .name
        ') || die "获取文件列表失败！"

    [[ -n "${FILES}" ]] || die "文件列表为空！"

    echo -e "${SUCCESS} 获取文件列表成功！"
    for script in ${FILES}; do
        echo -e "${INFO} 文件名：[\033[92m ${script} \033[0m]"
    done
}

validate_script() {
    local script_file="${1}"

    bash -n "${script_file}" >/dev/null 2>&1 ||
        die "语法检查失败：[\033[92m $(basename "${script_file}") \033[0m]"
}

ensure_target_dir() {
    if [[ ! -d "${TARGET_DIR}" ]]; then
        echo -e "${ERROR} 目标目录 [\033[92m ${TARGET_DIR} \033[0m] 不存在！正在创建..."
        mkdir -p "${TARGET_DIR}" || die "创建目标目录失败！"
    fi
}

sync_scripts() {
    local script
    local script_url

    for script in ${FILES}; do
        script_url="${BASE_URL}/${script}"
        echo -e "${STEPS} 正在同步文件：[\033[92m ${script} \033[0m]"

        download_file "${TEMP_DIR}/${script}" "${script_url}" ||
            die "下载失败：[\033[92m ${script} \033[0m]"
        validate_script "${TEMP_DIR}/${script}"
        chmod +x "${TEMP_DIR}/${script}" || die "设置权限失败：[\033[92m ${script} \033[0m]"
        mv -f "${TEMP_DIR}/${script}" "${TARGET_DIR}/" || die "移动失败：[\033[92m ${script} \033[0m]"
    done

    echo -e "${SUCCESS} 文件同步完成！"
}

main() {
    check_dependencies
    require_root
    create_temp_dir
    load_system_info
    get_remote_scripts
    ensure_target_dir
    sync_scripts
}

main "$@"
